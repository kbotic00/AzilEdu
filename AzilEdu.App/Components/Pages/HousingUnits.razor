    private int TotalUnits => housingUnits.Count;

    private int ActiveUnits => housingUnits.Count(housingUnit => housingUnit.IsActive);

    private int FullUnits => housingUnits.Count(housingUnit => (housingUnit.Capacity == housingUnit.Occupied));

    private int FreeUnitsSpace => housingUnits.Sum(housingUnit => (housingUnit.Capacity - housingUnit.Occupied));


}
