@page "/volunteers/edit/{Id:int}"
@rendermode InteractiveServer
@using AzilEdu.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" GutterBottom="true">Uredi volontera</MudText>

<MudForm @ref="form">
    <MudStack Spacing="2">
        <MudTextField @bind-Value="model.FirstName" Label="Ime" Required="true" />
        <MudTextField @bind-Value="model.LastName" Label="Prezime" Required="true" />
        <MudTextField @bind-Value="model.Email" Label="Email" />
        <MudTextField @bind-Value="model.Phone" Label="Telefon" />
        <MudTextField @bind-Value="model.Skills" Label="Vještine" />
        <MudTextField @bind-Value="model.Notes" Label="Napomena" Lines="3" />

        <MudSelect T="int"
                   Label="Status"
                   @bind-Value="model.VolunteerStatusId"
                   Variant="Variant.Outlined"
                   Required="true">
            @foreach (var s in statusList)
            {
                <MudSelectItem Value="@s.Id">@s.Name</MudSelectItem>
            }
        </MudSelect>

        <MudButton ButtonType="ButtonType.Button"
                   OnClick="@UpdateVolunteer"
                   Variant="Variant.Filled"
                   Color="Color.Primary">
            Spremi promjene
        </MudButton>
    </MudStack>
</MudForm>

@code {
    [Parameter] public int Id { get; set; }

    private MudForm? form;
    private SaveVolunteerDto model = new();
    private List<LookupDto> statusList = new();

    protected override async Task OnInitializedAsync()
    {
        statusList = await Http.GetFromJsonAsync<List<LookupDto>>("api/volunteerstatuses") ?? new();

        var v = await Http.GetFromJsonAsync<VolunteerDto>($"api/volunteers/{Id}");

        if (v is not null)
        {
            model = new SaveVolunteerDto
            {
                FirstName = v.FirstName,
                LastName = v.LastName,
                Email = v.Email,
                Phone = v.Phone,
                Skills = v.Skills,
                AvailableFrom = v.AvailableFrom,
                Notes = v.Notes,
                VolunteerStatusId = v.VolunteerStatusId
            };
        }

        if (model.VolunteerStatusId == 0 && statusList.Count > 0)
        {
            model.VolunteerStatusId = statusList[0].Id;
        }
    }

    private async Task UpdateVolunteer()
    {
        if (form is not null)
        {
            await form.ValidateAsync();

            if (!form.IsValid)
            {
                return;
            }
        }

        var response = await Http.PutAsJsonAsync($"api/volunteers/{Id}", model);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/volunteers");
        }
    }
}