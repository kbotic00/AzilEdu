@page "/employees"
@rendermode InteractiveServer
@using AzilEdu.Shared.DTOs
@using System.Net.Http.Json
@inject HttpClient Http

<MudText Typo="Typo.h4" GutterBottom="true">Zaposlenici</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="searchString"
                          Label="Pretraži zaposlenika"
                          Placeholder="Ime, prezime ili email"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>

        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Label="Pozicija"
                       @bind-Value="selectedPosition"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var p in positionList)
                {
                    <MudSelectItem Value="@p.Name">@p.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Label="Status"
                       @bind-Value="selectedStatus"
                       Variant="Variant.Outlined"
                       Clearable="true">
                @foreach (var s in statusList)
                {
                    <MudSelectItem Value="@s.Name">@s.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12" md="1" Class="d-flex align-center">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="ResetFilters">
                Očisti
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="@employees"
          Filter="FilterEmployees"
          Hover="true"
          Striped="true"
          Bordered="true"
          Dense="true">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<EmployeeDto, object>(x => x.LastName)">Prezime</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<EmployeeDto, object>(x => x.FirstName)">Ime</MudTableSortLabel></MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Telefon</MudTh>
        <MudTh>Broj zaposlenika</MudTh>
        <MudTh>Pozicija</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.LastName</MudTd>
        <MudTd>@context.FirstName</MudTd>
        <MudTd>@context.Email</MudTd>
        <MudTd>@context.Phone</MudTd>
        <MudTd>@context.EmployeeNumber</MudTd>
        <MudTd>@context.EmployeePositionName</MudTd>
        <MudTd>
            <MudChip T="string" Color="@GetStatusColor(context.EmployeeStatusName)">
                @context.EmployeeStatusName
            </MudChip>
        </MudTd>
    </RowTemplate>

    <NoRecordsContent>
        <MudText Typo="Typo.body1" Class="pa-4">
            Nema rezultata za zadane kriterije pretrage i filtera.
        </MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<EmployeeDto> employees = new();
    private List<LookupDto> positionList = new();
    private List<LookupDto> statusList = new();
    private string searchString = string.Empty;
    private string? selectedPosition;
    private string? selectedStatus;

    protected override async Task OnInitializedAsync()
    {
        positionList = await Http.GetFromJsonAsync<List<LookupDto>>("api/employeepositions") ?? new();
        statusList = await Http.GetFromJsonAsync<List<LookupDto>>("api/employeestatuses") ?? new();
        employees = await Http.GetFromJsonAsync<List<EmployeeDto>>("api/employees") ?? new();
    }

    private bool FilterEmployees(EmployeeDto e)
    {
        if (!string.IsNullOrWhiteSpace(searchString))
        {
            var term = searchString.Trim().ToLower();
            var matches =
                e.FirstName.ToLower().Contains(term) ||
                e.LastName.ToLower().Contains(term) ||
                e.Email.ToLower().Contains(term);
            if (!matches) return false;
        }

        if (!string.IsNullOrWhiteSpace(selectedPosition) &&
            !string.Equals(e.EmployeePositionName, selectedPosition, StringComparison.OrdinalIgnoreCase))
            return false;

        if (!string.IsNullOrWhiteSpace(selectedStatus) &&
            !string.Equals(e.EmployeeStatusName, selectedStatus, StringComparison.OrdinalIgnoreCase))
            return false;

        return true;
    }

    private void ResetFilters()
    {
        searchString = string.Empty;
        selectedPosition = null;
        selectedStatus = null;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Aktivan" => Color.Success,
        "Na bolovanju" => Color.Warning,
        "Na godišnjem" => Color.Info,
        "Neaktivan" => Color.Error,
        _ => Color.Default
    };
}
