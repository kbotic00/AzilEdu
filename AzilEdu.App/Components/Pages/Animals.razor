@page "/animals"

<MudText Typo="Typo.h4">Animals</MudText>
<MudText Typo="Typo.body1">
    Pregled zivotinja koje se nalaze u azilu:
    <MudPaper Class="pa-6"> 
        <MudText Typo="Typo.h5">Životinje u azilu</MudText>
        <MudText Typo="Typo.body2">
            Ovdje će se kasnije prikazivati osnovni podaci o životinjama.
        </MudText>
        <MudStack Row="true" Class="pa-6">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h5">Pas1</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h5">Pas2</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h5">Pas3</MudText>
                </MudPaper>
            </MudItem>
        </MudStack>
        <MudGrid Class="py-5">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4">Animals</MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4">Species</MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid Class="py-5">
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4">Animals</MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4">Species</MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4">Adopters</MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid Class="py-5">
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4">Glavni sadržaj</MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4">Bočni sadržaj</MudPaper>
                </MudItem>
            </MudGrid>

        <MudGrid Class="pa-5">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Sve životinje</MudText>
                    <MudText Typo="Typo.body2">
                        Pregled svih životinja evidentiranih u azilu.
                    </MudText>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-3">
                        Otvori pregled
                    </MudButton>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Vrste i pasmine</MudText>
                    <MudText Typo="Typo.body2">
                        Organizacija životinja prema vrstama i pasminama.
                    </MudText>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-3">
                        Otvori pregled
                    </MudButton>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Smještaj</MudText>
                    <MudText Typo="Typo.body2">
                        Pregled bokseva, kaveza i drugih smještajnih jedinica.
                    </MudText>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-3">
                        Otvori pregled
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary">
            Dodaj
        </MudButton>

        <MudButton EndIcon="@Icons.Material.Filled.ArrowForward"
                   Variant="Variant.Outlined"
                   Color="Color.Secondary">
            Nastavi
        </MudButton>
    </MudPaper>
</MudText>